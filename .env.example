# Frontend
VITE_API_BASE_URL=https://recipewallah-backend.vercel.app
VITE_API_RENDER_URL=https://recipewallah-backend.onrender.com

# Comma-separated list of allowed admin emails for UI visibility
VITE_ADMIN_EMAILS=owner@recipewallah.com

# Optional fallback links when the API has no release yet
VITE_FALLBACK_DIRECT_DOWNLOAD_URL=
VITE_PLAY_STORE_URL=
VITE_APP_STORE_URL=

# Backend
PORT=5000
MONGODB_URI=mongodb+srv://<atlas_username>:<atlas_password>@rwdatabase.v1wiawp.mongodb.net/?retryWrites=true&w=majority&appName=RWDatabase
JWT_SECRET=change-this-to-a-long-random-secret
CORS_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:5000

# Existing auth users collection (bcrypt hashes)
AUTH_DB_NAME=auth
AUTH_COLLECTION_NAME=user
AUTH_LOGIN_FIELD=email
AUTH_PASSWORD_FIELD=password
AUTH_FALLBACK_LOGIN_FIELDS=username,name

# Dropbox Integration
DROPBOX_ACCESS_TOKEN=
